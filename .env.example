# Environment Variables for Hostinger Deployment
# Set these in your Hostinger Panel under Node.js -> Environment Variables

NODE_ENV=production
PORT=3000

# Gemini API Key (Required for AI Voice Search)
GEMINI_API_KEY=your_gemini_api_key_here

# Zender WhatsApp & SMS SaaS Master Admin API Key
ZENDER_MASTER_API_KEY=your_sellerscampus_zender_master_api_key_here

# Any other specific environment variables your app uses:
# VITE_SOME_KEY=value
