rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterAdmin() {
      return isSignedIn() && "email" in request.auth.token && request.auth.token.email.matches("(?i)stratproamz@gmail.com");
    }

    function isOwnerOrStaff(shopId) {
      return isSignedIn() && (
        request.auth.uid == shopId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == shopId)
      );
    }

    // Generic Shop Data match
    match /{collection}/{docId} {
      allow read: if isMasterAdmin() || (isSignedIn() && resource.data.shopId != null && isOwnerOrStaff(resource.data.shopId));
      
      allow create: if isMasterAdmin() || (isSignedIn() && request.resource.data.shopId != null && isOwnerOrStaff(request.resource.data.shopId));

      allow update: if isMasterAdmin() || (isSignedIn() && resource.data.shopId != null && isOwnerOrStaff(resource.data.shopId) && request.resource.data.shopId == resource.data.shopId);

      allow delete: if isMasterAdmin() || (isSignedIn() && resource.data.shopId != null && isOwnerOrStaff(resource.data.shopId) && collection in ['recycleBin', 'categories', 'products']);
    }

    match /settings/{shopId} {
      allow read: if isMasterAdmin() || isOwnerOrStaff(shopId);
      allow write: if isMasterAdmin() || isOwnerOrStaff(shopId);
    }

    match /shops {
      allow read: if true;
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == shopId;
      allow update: if isMasterAdmin() || isOwnerOrStaff(shopId);
      allow delete: if isMasterAdmin();
    }
    
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isMasterAdmin() || isOwnerOrStaff(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId));
      allow write: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
  }
}
